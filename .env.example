# GitHub Configuration
GITHUB_TOKEN=Your_GitHub_API_Key_here
GITHUB_ORG=Your_ORG_NAME
GITHUB_ENTERPRISE_URL=Your_ENT_URL_NAME
GITHUB_ENTERPRISE_SLUG=Your_ENT_SLUG_URL_NAME

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@company.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=github-security@company.com
EMAIL_TO=management@company.com,security-team@company.com

# Slack Configuration (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#security-alerts

# Report Configuration
REPORT_OUTPUT_DIR=data/reports
HISTORY_DATA_DIR=data/history
CACHE_DIR=data/cache

# Feature Flags
ENABLE_DEPENDABOT=true
ENABLE_CODE_SCANNING=true
ENABLE_SECRET_SCANNING=true
ENABLE_SUPPLY_CHAIN=true

# Thresholds
CRITICAL_ALERT_THRESHOLD=1
HIGH_ALERT_THRESHOLD=5
MTTR_SLA_DAYS=7

# Logging
LOG_FILE=data/app.log
# For production - clean output (only important messages)
# LOG_LEVEL=INFO
# For debugging - verbose output (see all skipped repos)
LOG_LEVEL=DEBUG

# ── Tool / Company metadata (shown in Executive Summary) ─────────────────────
REPORT_TITLE=GitHub Security Reporter
COMPANY_NAME=Alien Security
DEVELOPED_BY=Dev Name
TOOL_VERSION=1.0.0
COPYRIGHT_YEAR=2026
COMPANY_WEBSITE=https://company.com
TOOL_GITHUB_REPO=https://github.com/repo/
SUPPORT_EMAIL=support@xyz.com