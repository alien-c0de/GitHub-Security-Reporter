"
# Ignore all .env files
.env

# Ignore all JSON files everywhere
*.json

# Ignore Excel files
*.xlsx
*.log
data/app.log

# Reports folder: Ignore everything EXCEPT the .gitkeep
data/reports/*
!data/reports/.gitkeep

# History folder: Ignore everything EXCEPT .gitkeep and the snapshots directory
data/history/*
!data/history/.gitkeep
!data/history/snapshots/

# Snapshots folder: Ignore everything EXCEPT the .gitkeep
data/history/snapshots/*
!data/history/snapshots/.gitkeep

__pycache__/
" | Out-File -FilePath .gitignore -Encoding utf8
